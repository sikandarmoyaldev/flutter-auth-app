        "@types/node": "^25.6.0",
        "drizzle-kit": "^0.31.10",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.3",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    }
